<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:orientation="vertical"
    android:padding="30dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end">

        <Button
            android:id="@+id/btnLanguageToggle"
            android:layout_width="72dp"
            android:layout_height="44dp"
            android:backgroundTint="#334155"
            android:text="БГ"
            android:textAllCaps="false"
            android:textColor="#E2E8F0"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

    <TextView
        android:id="@+id/tvLoginTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Heritage Hunt"
        android:textColor="#F8FAFC"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvLoginSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="28dp"
        android:text="Log in to explore nearby places, keep your history, and complete daily challenges."
        android:textColor="#94A3B8"
        android:textSize="15sp" />

    <EditText
        android:id="@+id/etLoginEmail"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="12dp"
        android:background="#1E293B"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:paddingStart="15dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#64748B" />

    <EditText
        android:id="@+id/etLoginPassword"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="22dp"
        android:background="#1E293B"
        android:hint="Password"
        android:inputType="textPassword"
        android:paddingStart="15dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#64748B" />

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#38BDF8"
        android:text="LOGIN"
        android:textColor="#082F49"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnOpenRegister"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#334155"
        android:text="REGISTER"
        android:textColor="#E2E8F0"
        android:textStyle="bold" />

    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/game_bg">

    <TextureView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#3307111F" />

    <com.example.game_vol1.ArPinModelView
        android:id="@+id/arPinModel"
        android:layout_width="220dp"
        android:layout_height="260dp"
        android:layout_gravity="center"
        android:contentDescription="3D heritage location pin" />

    <View
        android:id="@+id/arScanLine"
        android:layout_width="210dp"
        android:layout_height="3dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_ar_scan_line" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="20dp"
        android:background="@drawable/bg_ar_panel"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvArTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/game_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvArSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/game_text_muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvArLiveHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Scanning direction..."
            android:textColor="@color/game_secondary"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="20dp"
        android:background="@drawable/bg_ar_panel"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvArStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Move the phone slowly. 3D pin is active."
            android:textColor="@color/game_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnScanPin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_accent_button"
            android:text="Scan location pin"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCloseAr"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_secondary_button"
            android:text="Back to map"
            android:textAllCaps="false"
            android:textColor="@color/game_text"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Round Result"
        android:textColor="#93C5FD"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRoundResultTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Location"
        android:textColor="#F8FAFC"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRoundResultSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="City"
        android:textColor="#CBD5E1"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvRoundScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="0 pts"
        android:textColor="#FDBA74"
        android:textSize="36sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRoundDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="0.0 km away"
        android:textColor="#E2E8F0"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvRoundFact"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:background="#111C34"
        android:padding="16dp"
        android:text="Fun fact"
        android:textColor="#E2E8F0"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvRoundUnlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Unlock message"
        android:textColor="#86EFAC"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvSessionRunningScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Session score: 0"
        android:textColor="#CBD5E1"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btnContinueRound"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="28dp"
        android:backgroundTint="#38BDF8"
        android:text="Next round"
        android:textColor="#082F49"
        android:textStyle="bold" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0C1220"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvSplashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Map Hunt"
        android:textColor="#F5F7FA"
        android:textSize="38sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSplashSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="GeoGuessr-style landmark game"
        android:textColor="#9DB2CE"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/tvSplashLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="Loading your next run..."
        android:textColor="#D7E3F4"
        android:textSize="16sp" />

</LinearLayout>
